# ==============================================================================
# Rover Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit your raw .env file to public version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Environment & Domain URLs
# ------------------------------------------------------------------------------
# Public URL where the Web Frontend is hosted (e.g., http://localhost:3000 or https://rover.yourdomain.com)
FRONTEND_URL=http://localhost:3000

# Public URL where the FastAPI Backend is hosted (e.g., http://localhost:8000 or https://api.rover.yourdomain.com)
BACKEND_URL=http://localhost:8000

# Explicit OAuth Callback URI Override (optional; defaults to ${FRONTEND_URL}/auth/callback)
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# ------------------------------------------------------------------------------
# GitHub OAuth & GitHub App Configuration
# ------------------------------------------------------------------------------
# 1. GitHub OAuth Credentials (for user authentication & login)
# Obtain from your GitHub App general settings page (https://github.com/settings/apps)
GITHUB_CLIENT_ID=your_github_app_client_id_here
GITHUB_CLIENT_SECRET=your_github_app_client_secret_here

# 2. GitHub App Integration Credentials (for repository scanning & PR automation)
USE_GITHUB_APP=true
GITHUB_APP_ID=your_github_app_id_here
GITHUB_PRIVATE_KEY=keys/private-key.pem
GITHUB_INSTALLATION_ID=your_installation_id_here
WEBHOOK_SECRET=your_configured_webhook_secret_here

# Classic Personal Access Token (PAT) used only when USE_GITHUB_APP=false
GITHUB_TOKEN=your_classic_github_token_here

# ------------------------------------------------------------------------------
# LLM Providers Configuration
# ------------------------------------------------------------------------------
# Primary API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback OpenRouter API Key (https://openrouter.ai/) for DeepSeek v3
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat:free

# ------------------------------------------------------------------------------
# Security & Databases
# ------------------------------------------------------------------------------
SECRET_KEY=rover-super-secret-key-change-in-production-32bytes!
DATABASE_URL=sqlite+aiosqlite:///./rover.db
REDIS_URL=redis://localhost:6379/0